# Tester.io SERVER env template — copy to .env.local and fill in real values.
# None of these are VITE_-prefixed; they must never reach the browser.

PORT=5000

# Admin dashboard password (unlocks /api/admin/*)
DASHBOARD_PASSWORD=

# Supabase service_role key (bypasses RLS — backend only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM=Tester.io <onboarding@resend.dev>
RESEND_REPLY_TO=

# Restrict CORS to the frontend origin (optional; defaults to allow-all)
CORS_ORIGIN=

# Optional server-side Google Sheets writes (the live frontend uses Apps Script instead)
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_RANGE=Sheet1!A:D
