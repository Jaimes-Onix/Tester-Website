# Tester.io CLIENT env template — copy to .env.local and fill in real values.
# Only VITE_-prefixed vars are exposed to the browser.

KIE_API_KEY=

# Supabase (anon key is public by design, gated by RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Apps Script web app URL for the contact form
VITE_GOOGLE_SHEETS_URL=

# Backend API base URL. Empty for local dev (uses the Vite proxy); set to the
# deployed backend origin in production, e.g. https://tester-api.vercel.app
VITE_API_BASE_URL=
